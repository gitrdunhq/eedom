{% if error %}
**blast-radius**: {{ error }}
{% elif not findings %}
{% if summary.get("symbols_indexed", 0) %}
**Blast Radius**: {{ summary.symbols_indexed }} symbols indexed, no issues found
{% endif %}
{% else %}
<details open><summary>💥 <b>Blast Radius ({{ findings | length }})</b></summary>

{% for sev in ["critical", "high", "medium", "info"] %}
{% set items = findings_by_sev.get(sev, []) %}
{% if items %}
{% if sev == "critical" %}**🔴 CRITICAL ({{ items | length }})**
{% elif sev == "high" %}**🟠 HIGH ({{ items | length }})**
{% elif sev == "medium" %}**🟡 MEDIUM ({{ items | length }})**
{% else %}**ℹ️ INFO ({{ items | length }})**
{% endif %}

{% for f in items[:10] %}
{% set extra = "" %}
{% if "dependents" in f %}{%- set extra = " — " ~ f.dependents ~ " dependents" -%}
{% elif "calls_out" in f %}{%- set extra = " — " ~ f.calls_out ~ " outgoing calls" -%}
{% elif "depth" in f %}{%- set extra = " — depth " ~ f.depth -%}
{% endif %}
{% if f.get("name") %}- `{{ f.name }}` ({{ f.get("file", "") }}){{ extra }} — {{ f.get("check", "?") }}
{% elif "file_a" in f %}- `{{ f.file_a }}` ↔ `{{ f.file_b }}` — {{ f.get("check", "?") }}
{% elif f.get("file") %}- `{{ f.file }}` — {{ f.get("check", "?") }}
{% else %}- {{ f.get("description", "") }}{{ extra }}
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}

*{{ summary.get("symbols_indexed", 0) }} symbols, {{ summary.get("edges", 0) }} edges, {{ summary.get("checks_run", 0) }} checks*

</details>

{% endif %}
